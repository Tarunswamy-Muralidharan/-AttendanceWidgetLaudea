<?xml version="1.0" encoding="utf-8"?>
<!--
  Bundled Firebase Remote Config defaults. Loaded sync from APK on app
  start (10ms) so first-ever launches show the right ad state without
  waiting for fetchAndActivate (~500ms). Server values still override
  whenever they arrive.
-->
<defaultsMap>
    <entry>
        <!-- Default false. Flip the server-side `ads_enabled` flag in
             Firebase Console → Remote Config to true when ready to
             monetise. Every existing client picks it up within the 1h
             fetch interval; new installs see a ~500ms blank then ads
             appear after fetchAndActivate. No APK update required. -->
        <key>ads_enabled</key>
        <value>false</value>
    </entry>
    <entry>
        <key>chess_backend_v2</key>
        <value>true</value>
    </entry>
    <entry>
        <key>maintenance_enabled</key>
        <value>false</value>
    </entry>
    <entry>
        <key>maintenance_message</key>
        <value></value>
    </entry>
    <entry>
        <key>sideload_block_enabled</key>
        <value>false</value>
    </entry>
</defaultsMap>
