<?xml version="1.0" encoding="utf-8"?>
<!--
  Bundled Firebase Remote Config defaults. Loaded sync from APK on app
  start (10ms) so first-ever launches show the right ad state without
  waiting for fetchAndActivate (~500ms). Server values still override
  whenever they arrive.
-->
<defaultsMap>
    <entry>
        <!-- Default false. Flip the server-side `ads_enabled` flag in
             Firebase Console → Remote Config to true when ready to
             monetise. Every existing client picks it up within the 1h
             fetch interval; new installs see a ~500ms blank then ads
             appear after fetchAndActivate. No APK update required. -->
        <key>ads_enabled</key>
        <value>false</value>
    </entry>
    <entry>
        <key>chess_backend_v2</key>
        <value>true</value>
    </entry>
    <entry>
        <key>maintenance_enabled</key>
        <value>false</value>
    </entry>
    <entry>
        <key>maintenance_message</key>
        <value></value>
    </entry>
    <entry>
        <key>sideload_block_enabled</key>
        <value>false</value>
    </entry>
    <entry>
        <!-- false = serve real production AdMob ads (default for prod).
             true  = serve AdMob's public test ads (no revenue, no policy
             risk). Flip this in Firebase Console for safe demos / when
             AdMob flags traffic / before app store review. -->
        <key>ads_use_test_ids</key>
        <value>false</value>
    </entry>
    <entry>
        <!-- Tournament feature gate. While false the Chess "Tourney" tile
             and Profile "Tournament Approvals" tile show a "Feature under
             development" toast on tap instead of opening the screens.
             Flip true in Firebase Console once the tournament flow is
             ready to ship. -->
        <key>tournament_enabled</key>
        <value>false</value>
    </entry>
    <entry>
        <!-- Class marks comparison feature. While false:
             - ClassMarksUploadWorker bails on every run (no D1 writes)
             - Compare entry on CAMarksScreen header stays hidden
             Flip true in Firebase Console after enough students per class
             have signed in (server-side k=15 anonymity floor still applies
             regardless). -->
        <key>class_compare_enabled</key>
        <value>false</value>
    </entry>
</defaultsMap>
