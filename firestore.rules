rules_version = '2';

// JustPass Firestore security rules.
//
// Read model: chess_* collections + announcements are public-read so
// clients work BEFORE Firebase Anonymous Auth completes (the SDK
// signs in lazily on first connect; the chess profile load happens
// before that, so a `request.auth != null` read rule here would 503
// the chess screen on every cold launch). The data is anonymous chess
// nicknames + ratings + game counts — already public-by-design.
//
// Write model: every write requires `request.auth != null`. We can't
// bind playerId to the auth UID until v3 migrates `chess_profiles`
// keys away from `p_<rollNumber-hash>`, so cross-user writes are
// theoretically possible — the v3 plan tightens this. Until then the
// per-collection rules below at least gate the write surface (status
// transitions, doc shape, no client deletes on history, etc.).

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── chess_online ────────────────────────────────────────────────
    match /chess_online/{playerId} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.data.keys().hasOnly([
          "displayName", "timestamp", "wins", "losses",
          "draws", "gamesPlayed",
        ])
        && request.resource.data.timestamp is number;
      allow delete: if request.auth != null;
    }

    // ─── chess_profiles ──────────────────────────────────────────────
    // Stat-bump writes from `recordGameResult` come from the OPPONENT
    // and only touch the four numeric fields. Anything else requires
    // auth (and we accept any authed writer because we can't yet bind
    // the doc key to auth.uid).
    match /chess_profiles/{playerId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if false;
    }

    // ─── chess_challenges ────────────────────────────────────────────
    match /chess_challenges/{challengeId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.fromId is string
        && request.resource.data.toId is string
        && request.resource.data.fromId != request.resource.data.toId
        && request.resource.data.status == "pending";
      allow update: if request.auth != null
        && request.resource.data.status in ["pending", "accepted", "declined", "cancelled"];
      allow delete: if request.auth != null;
    }

    // ─── chess_friends ───────────────────────────────────────────────
    match /chess_friends/{requestId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.fromId is string
        && request.resource.data.toId is string
        && request.resource.data.fromId != request.resource.data.toId
        && request.resource.data.status == "pending";
      allow update: if request.auth != null
        && resource.data.status == "pending"
        && request.resource.data.status in ["accepted", "declined"];
      allow delete: if request.auth != null;
    }

    // ─── chess_match_history ─────────────────────────────────────────
    match /chess_match_history/{historyId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(["leftAt", "claimed", "resultChecked"]);
      allow delete: if false;
    }

    // ─── announcements ───────────────────────────────────────────────
    // Read-only for clients; written from the Firebase Console / Cloud
    // Functions only. Public read because the app shows announcements
    // before any auth flow runs.
    match /announcements/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // ─── tournament_requests ──────────────────────────────────────────
    // Anyone authed can create a request (with the required fields). Only
    // the creator can read their own. Only an admin can read all + approve
    // /reject. Phone OTP verification is enforced client-side via Firebase
    // Phone Auth — server can't easily check that a phone-verified
    // signInWithCredential happened in the same session. Rate-limit via
    // a per-creator quota in Cloud Functions if abuse appears.
    match /tournament_requests/{requestId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.creatorPlayerId is string
        && request.resource.data.creatorPhone is string
        && request.resource.data.tournamentName is string
        && request.resource.data.status == "pending";
      allow update: if request.auth != null
        && resource.data.status == "pending"
        && request.resource.data.status in ["approved", "rejected"];
      allow delete: if false;
    }

    // ─── admin_roles + admin_uids ────────────────────────────────────
    // Two parallel collections. admin_roles is the human-readable
    // record (keyed by p_${rollHash}, has name + addedAt + addedBy).
    // admin_uids is the rules-engine shadow (keyed by Firebase Auth
    // UID, looked up via exists() so other rules can authorise writes).
    //
    // Bootstrap: create admin_roles/p_678fd629 and admin_uids/{your_uid}
    // manually via Firebase Console. After that, existing admins can
    // grant via the in-app UI; new admins self-register their UID on
    // their first app open.

    match /admin_roles/{playerId} {
      allow read: if true;  // public so the cache can populate without auth
      allow create, update, delete: if request.auth != null
        && exists(/databases/$(database)/documents/admin_uids/$(request.auth.uid));
    }

    match /admin_uids/{firebaseUid} {
      allow read: if request.auth != null;
      // Self-registration: a user can write admin_uids/{their own uid}
      // ONLY if their declared playerId is in admin_roles. Stops anyone
      // from spoofing themselves into admin_uids.
      allow create: if request.auth != null
        && request.auth.uid == firebaseUid
        && request.resource.data.playerId is string
        && exists(/databases/$(database)/documents/admin_roles/$(request.resource.data.playerId));
      // Existing admins can wipe stale entries (e.g. when removing an
      // admin via Manage Admins -> the orphaned uid sweep).
      allow delete: if request.auth != null
        && exists(/databases/$(database)/documents/admin_uids/$(request.auth.uid));
      allow update: if false;
    }

    // ─── bug_reports ─────────────────────────────────────────────────
    // Authed users create reports about themselves. Admin reads all and
    // updates status. No deletion path (keep history).
    match /bug_reports/{reportId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.title is string
        && request.resource.data.description is string;
      allow update: if request.auth != null;
      allow delete: if false;
    }

    // ─── tournaments ─────────────────────────────────────────────────
    // Approved tournaments. Only writeable by Cloud Functions / admin
    // path that reads the parent request. Public read since users browse
    // the lobby for tournaments to join.
    match /tournaments/{tournamentId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null;
    }

    // Catch-all for everything else.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
