rules_version = '2';

// JustPass Firestore security rules.
//
// Read model: chess_* collections + announcements are public-read so
// clients work BEFORE Firebase Anonymous Auth completes (the SDK
// signs in lazily on first connect; the chess profile load happens
// before that, so a `request.auth != null` read rule here would 503
// the chess screen on every cold launch). The data is anonymous chess
// nicknames + ratings + game counts — already public-by-design.
//
// Write model: every write requires `request.auth != null`. We can't
// bind playerId to the auth UID until v3 migrates `chess_profiles`
// keys away from `p_<rollNumber-hash>`, so cross-user writes are
// theoretically possible — the v3 plan tightens this. Until then the
// per-collection rules below at least gate the write surface (status
// transitions, doc shape, no client deletes on history, etc.).

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── chess_online ────────────────────────────────────────────────
    match /chess_online/{playerId} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.data.keys().hasOnly([
          "displayName", "timestamp", "wins", "losses",
          "draws", "gamesPlayed",
        ])
        && request.resource.data.timestamp is number;
      allow delete: if request.auth != null;
    }

    // ─── chess_profiles ──────────────────────────────────────────────
    // Stat-bump writes from `recordGameResult` come from the OPPONENT
    // and only touch the four numeric fields. Anything else requires
    // auth (and we accept any authed writer because we can't yet bind
    // the doc key to auth.uid).
    match /chess_profiles/{playerId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if false;
    }

    // ─── chess_challenges ────────────────────────────────────────────
    match /chess_challenges/{challengeId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.fromId is string
        && request.resource.data.toId is string
        && request.resource.data.fromId != request.resource.data.toId
        && request.resource.data.status == "pending";
      allow update: if request.auth != null
        && request.resource.data.status in ["pending", "accepted", "declined", "cancelled"];
      allow delete: if request.auth != null;
    }

    // ─── chess_friends ───────────────────────────────────────────────
    match /chess_friends/{requestId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.fromId is string
        && request.resource.data.toId is string
        && request.resource.data.fromId != request.resource.data.toId
        && request.resource.data.status == "pending";
      allow update: if request.auth != null
        && resource.data.status == "pending"
        && request.resource.data.status in ["accepted", "declined"];
      allow delete: if request.auth != null;
    }

    // ─── chess_match_history ─────────────────────────────────────────
    match /chess_match_history/{historyId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(["leftAt", "claimed", "resultChecked"]);
      allow delete: if false;
    }

    // ─── announcements ───────────────────────────────────────────────
    // Read-only for clients; written from the Firebase Console / Cloud
    // Functions only. Public read because the app shows announcements
    // before any auth flow runs.
    match /announcements/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // Catch-all for everything else.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
